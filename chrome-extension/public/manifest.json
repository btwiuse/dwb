{
	"manifest_version": 3,
	"name": "DeepWiki Browser",
	"description": "Automatically track DeepWiki browsing sessions and organize them by repository for easy navigation.",
	"version": "0.1.0",
	"permissions": ["tabs", "storage", "sidePanel"],
	"host_permissions": ["https://deepwiki.com/*"],
	"action": {
		"default_icon": {
			"16": "icons/icon-16.png",
			"48": "icons/icon-48.png",
			"128": "icons/icon-128.png"
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"side_panel": {
		"default_path": "sidepanel.html"
	}
}
